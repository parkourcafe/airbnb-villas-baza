{
  "name": "@bai/config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript, ESLint and Prettier configuration for the BAI monorepo.",
  "type": "module",
  "exports": {
    "./eslint/base": "./eslint/base.mjs",
    "./eslint/next": "./eslint/next.mjs",
    "./eslint/react": "./eslint/react.mjs",
    "./prettier": "./prettier/index.mjs",
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/node.json": "./tsconfig/node.json",
    "./tsconfig/react-library.json": "./tsconfig/react-library.json",
    "./tsconfig/nextjs.json": "./tsconfig/nextjs.json"
  },
  "files": [
    "eslint",
    "prettier",
    "tsconfig"
  ],
  "scripts": {
    "lint": "echo \"@bai/config has no lintable source\" && exit 0",
    "typecheck": "echo \"@bai/config has no typecheckable source\" && exit 0",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "@eslint/js": "9.17.0",
    "@next/eslint-plugin-next": "15.1.3",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-react": "7.37.3",
    "eslint-plugin-react-hooks": "5.1.0",
    "globals": "15.14.0",
    "typescript-eslint": "8.18.2"
  },
  "peerDependencies": {
    "eslint": "^9",
    "prettier": "^3",
    "typescript": "^5"
  }
}
