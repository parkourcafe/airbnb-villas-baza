{
  "name": "@bai/ui",
  "version": "0.0.0",
  "private": true,
  "description": "BAI shared UI kit: shadcn/ui-style primitives, theme tokens and the Tailwind preset. Consumed as source by apps/web via transpilePackages.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./src/styles/globals.css",
    "./tailwind-preset": {
      "types": "./tailwind-preset.ts",
      "default": "./tailwind-preset.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "tailwind-preset.ts"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf .turbo coverage *.tsbuildinfo"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-tabs": "1.1.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.469.0",
    "tailwind-merge": "2.6.0",
    "tailwindcss-animate": "1.0.7"
  },
  "devDependencies": {
    "@bai/config": "workspace:*",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "eslint": "9.17.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^3.4"
  }
}
