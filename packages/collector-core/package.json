{
  "name": "@bai/collector-core",
  "version": "0.0.0",
  "private": true,
  "description": "Pure, source-agnostic logic for browser-operated collection: market/area definitions, search-cell planning, HTML card/detail parsing, listing-id parsing, deduplication and snapshot integrity. No browser, network or database dependency.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./fixtures": {
      "types": "./src/fixtures.ts",
      "default": "./src/fixtures.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf .turbo coverage *.tsbuildinfo"
  },
  "dependencies": {
    "@bai/domain": "workspace:*"
  },
  "devDependencies": {
    "@bai/config": "workspace:*",
    "@types/node": "22.20.1",
    "eslint": "9.39.5",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  }
}
