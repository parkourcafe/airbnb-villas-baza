{
  "name": "@bai/db",
  "version": "0.0.0",
  "private": true,
  "description": "Lazy database clients, repositories and keyset pagination helpers. Supabase wiring arrives in milestone 1.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf .turbo coverage *.tsbuildinfo",
    "test:db": "vitest run --config vitest.db.config.ts"
  },
  "dependencies": {
    "@bai/domain": "workspace:*",
    "@supabase/supabase-js": "2.110.7",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@bai/config": "workspace:*",
    "@electric-sql/pglite": "0.5.4",
    "@types/node": "22.20.1",
    "eslint": "9.39.5",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  }
}
