# =============================================================================
# BAI environment variables (names only - never commit real values).
# Copy to `.env` for local development. Server-only variables MUST NOT be
# prefixed with NEXT_PUBLIC_. All clients are lazily initialized.
# Supabase and worker variables are wired up from milestone 1 onward.
# =============================================================================

# --- Public (safe to expose to the browser) ---------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Server only (never sent to the browser) --------------------------------
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# --- Cron / worker ----------------------------------------------------------
CRON_SECRET=
WORKER_ID=
WORKER_POLL_INTERVAL_MS=5000
WORKER_CONCURRENCY=2

# --- Application ------------------------------------------------------------
APP_URL=http://localhost:3000
APP_TIMEZONE=Asia/Makassar

# --- Map (configurable tile provider) ---------------------------------------
MAP_STYLE_URL=
MAP_TILE_API_KEY=

# --- Observability (optional after MVP) -------------------------------------
ANALYTICS_PROVIDER=
SENTRY_DSN=
