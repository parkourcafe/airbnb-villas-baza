{
  "name": "@bai/worker",
  "version": "0.0.0",
  "private": true,
  "description": "BAI long-running worker: polls the job queue, runs imports and adapters, and generates snapshots/events. Milestone 0 ships the process skeleton and smoke mode.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "smoke": "tsx src/index.ts --smoke",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:db": "echo \"@bai/worker: database integration tests arrive in milestone 1\" && exit 0",
    "clean": "rm -rf dist .turbo coverage *.tsbuildinfo"
  },
  "dependencies": {
    "@bai/db": "workspace:*",
    "@bai/domain": "workspace:*",
    "@bai/source-sdk": "workspace:*",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@bai/config": "workspace:*",
    "@types/node": "22.10.2",
    "eslint": "9.17.0",
    "tsup": "8.3.5",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
