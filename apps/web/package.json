{
  "name": "@bai/web",
  "version": "0.0.0",
  "private": true,
  "description": "BAI Next.js App Router web application (public site + dashboard shell). Milestone 0 ships the foundation and design system.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "echo \"@bai/web has no unit tests in milestone 0; see test:e2e\" && exit 0",
    "test:e2e": "playwright test",
    "test:db": "echo \"@bai/web: database tests arrive in milestone 1\" && exit 0",
    "clean": "rm -rf .next dist .turbo coverage playwright-report test-results *.tsbuildinfo"
  },
  "dependencies": {
    "@bai/domain": "workspace:*",
    "@bai/ui": "workspace:*",
    "@supabase/ssr": "0.12.3",
    "@supabase/supabase-js": "2.110.7",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@bai/config": "workspace:*",
    "@playwright/test": "1.56.1",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.4",
    "eslint": "9.39.5",
    "postcss": "8.5.19",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "1.0.7",
    "typescript": "5.9.3"
  }
}
